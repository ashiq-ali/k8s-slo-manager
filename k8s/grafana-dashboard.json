{
  "title": "SLO Error Budget Dashboard",
  "uid": "slo-error-budget",
  "tags": ["slo", "error-budget", "sre"],
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "stat",
      "title": "Checkout Availability SLI",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "slo:checkout_availability:ratio_rate5m * 100",
          "legendFormat": "SLI %"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 99.5},
            {"color": "green", "value": 99.9}
          ]
        }
      },
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 4}}
    },
    {
      "type": "stat",
      "title": "Checkout Error Budget Remaining",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "((1 - slo:checkout_availability:ratio_rate1h) / (1 - 0.999) / 720) * 100",
          "legendFormat": "Budget remaining %"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "red", "value": 0},
            {"color": "yellow", "value": 10},
            {"color": "green", "value": 50}
          ]
        }
      },
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1}}
    },
    {
      "type": "stat",
      "title": "Checkout Burn Rate (1h)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "(1 - slo:checkout_availability:ratio_rate1h) / (1 - 0.999)",
          "legendFormat": "Burn Rate"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "green", "value": 0},
            {"color": "yellow", "value": 3},
            {"color": "orange", "value": 6},
            {"color": "red", "value": 14.4}
          ]
        }
      },
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2}}
    },
    {
      "type": "timeseries",
      "title": "SLI Over Time — All Services",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "slo:checkout_availability:ratio_rate5m",
          "legendFormat": "checkout-availability"
        },
        {
          "expr": "slo:checkout_latency_p99:ratio_rate5m",
          "legendFormat": "checkout-latency-p99"
        },
        {
          "expr": "slo:api_gateway_availability:ratio_rate5m",
          "legendFormat": "api-gateway-availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4,
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Burn Rate — Checkout Availability",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "(1 - slo:checkout_availability:ratio_rate5m) / (1 - 0.999)",
          "legendFormat": "burn rate 5m"
        },
        {
          "expr": "(1 - slo:checkout_availability:ratio_rate1h) / (1 - 0.999)",
          "legendFormat": "burn rate 1h"
        },
        {
          "expr": "(1 - slo:checkout_availability:ratio_rate6h) / (1 - 0.999)",
          "legendFormat": "burn rate 6h"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {
        "annotation": {
          "list": [
            {"name": "Fast burn threshold (14.4×)", "expr": "vector(14.4)", "hide": false},
            {"name": "Slow burn threshold (6×)",    "expr": "vector(6)",    "hide": false}
          ]
        }
      }
    }
  ]
}
